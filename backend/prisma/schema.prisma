datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  CUSTOMER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

model User {
  id               String         @id @default(uuid())
  email            String         @unique
  password         String?
  name             String
  role             Role           @default(CUSTOMER)
  status           UserStatus     @default(ACTIVE)
  provider         String         @default("credentials")
  profileImage     String?
  welcomeEmailSent Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  refreshTokens    RefreshToken[]
  addresses        Address[]
  cart             Cart?
  orders           Order[]

  @@index([email])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}

model Address {
  id           String   @id @default(uuid())
  label        String // e.g. "Home", "Office", "Other"
  houseNumber  String
  buildingName String?
  area         String
  landmark     String?
  city         String
  district     String
  state        String
  pincode      String
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  foods       Food[]
}

model Food {
  id              String      @id @default(uuid())
  name            String
  description     String
  price           Decimal     @db.Decimal(10, 2)
  imageUrl        String
  rating          Float       @default(5.0)
  preparationTime Int // in minutes
  featured        Boolean     @default(false)
  isAvailable     Boolean     @default(true)
  isVeg           Boolean     @default(false)
  isBestseller    Boolean     @default(false)
  isTrending      Boolean     @default(false)
  isNew           Boolean     @default(false)
  spiceLevel      String?     @default("Medium")
  categoryId      String
  category        Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  cartItems       CartItem[]
  orderItems      OrderItem[]

  @@index([categoryId])
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     CartItem[]
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  foodId    String
  food      Food     @relation(fields: [foodId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, foodId])
}

model Order {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  total     Decimal     @db.Decimal(10, 2)
  tax       Decimal     @db.Decimal(10, 2)
  discount  Decimal     @db.Decimal(10, 2) @default(0.00)
  couponId  String?
  coupon    Coupon?     @relation(fields: [couponId], references: [id], onDelete: SetNull)
  addressId String
  address   Address     @relation(fields: [addressId], references: [id], onDelete: Restrict)
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  items     OrderItem[]

  @@index([userId])
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  foodId    String
  food      Food     @relation(fields: [foodId], references: [id], onDelete: Restrict)
  price     Decimal  @db.Decimal(10, 2) // Price snapshotted at time of purchase
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
}

model Coupon {
  id        String   @id @default(uuid())
  code      String   @unique
  discount  Decimal  @db.Decimal(10, 2) // Flat discount or percentage discount represented as integer
  expiresAt DateTime
  isActive  Boolean  @default(true)
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String // e.g. "CREATE_FOOD", "UPDATE_ORDER", "BLOCK_USER"
  performedBy String // User email or ID
  entityType  String // e.g. "FOOD", "ORDER", "USER"
  entityId    String?
  timestamp   DateTime @default(now())

  @@index([timestamp])
}
